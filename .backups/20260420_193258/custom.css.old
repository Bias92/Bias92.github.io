/* ============================================================
   scaling-book style override for Hugo PaperMod
   - Dark mode only (light mode = PaperMod default)
   - Cyan accent (#2698ba), Roboto + Roboto Slab
   - Sidebar sticky ToC
   Place this file at: assets/css/extended/custom.css
   ============================================================ */

/* ---------- Google Fonts ---------- */
@import url('https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&family=Roboto+Slab:wght@300;400;500;600;700&display=swap');

/* ============================================================
   DARK MODE OVERRIDES
   PaperMod applies .dark on <body> when dark theme is active.
   ============================================================ */
.dark {
    /* Core palette from scaling-book dark */
    --theme: #1c1c1d;              /* page bg */
    --entry: #212529;              /* card/entry bg */
    --primary: #e8e8e8;            /* main text */
    --secondary: #a0a0a0;          /* muted text */
    --tertiary: #424246;           /* borders */
    --content: #e8e8e8;            /* body text */
    --code-block-bg: #2c3237;      /* code block bg */
    --code-bg: #2c3237;            /* inline code bg */
    --border: #424246;             /* dividers */

    /* Custom accent (scaling-book dark cyan) */
    --accent: #2698ba;
    --accent-hover: #3bb0d3;
}

/* ---------- Typography (dark only) ---------- */
.dark body,
.dark .post-content,
.dark .main {
    font-family: 'Roboto', -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
    font-weight: 400;
    line-height: 1.7;
    color: var(--content);
    background-color: var(--theme);
}

.dark h1,
.dark h2,
.dark h3,
.dark h4,
.dark h5,
.dark h6,
.dark .post-title,
.dark .entry-header {
    font-family: 'Roboto Slab', Georgia, serif;
    font-weight: 500;
    color: var(--primary);
    letter-spacing: -0.01em;
}

.dark .post-title {
    font-size: 2.5rem;
    line-height: 1.2;
    margin-bottom: 0.5em;
}

.dark .post-content h1 { font-size: 2.25rem; }
.dark .post-content h2 {
    font-size: 1.8rem;
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.3em;
    margin-top: 1.8em;
}
.dark .post-content h3 {
    font-size: 1.4rem;
    margin-top: 1.5em;
}
.dark .post-content h4 { font-size: 1.15rem; }

/* ---------- Links (dark only) ---------- */
.dark a,
.dark .post-content a {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.15s ease;
}
.dark a:hover,
.dark .post-content a:hover {
    color: var(--accent-hover);
    border-bottom: 1px solid var(--accent);
}

/* ---------- Inline code ---------- */
.dark .post-content code:not(pre code) {
    color: var(--accent);
    background-color: rgba(38, 152, 186, 0.1);
    border-radius: 3px;
    padding: 2px 5px;
    font-family: 'SF Mono', 'Menlo', 'Monaco', 'Consolas', monospace;
    font-size: 0.9em;
}

/* ---------- Code blocks ---------- */
.dark .post-content pre {
    background-color: var(--code-block-bg);
    border-radius: 6px;
    padding: 12px 16px;
    border: 1px solid var(--border);
    overflow-x: auto;
    font-family: 'SF Mono', 'Menlo', 'Monaco', 'Consolas', monospace;
    font-size: 0.875rem;
    line-height: 1.5;
}
.dark .post-content pre code {
    background: transparent;
    padding: 0;
    color: var(--content);
}

/* ---------- Blockquote ---------- */
.dark .post-content blockquote {
    border-left: 4px solid var(--accent);
    background: rgba(38, 152, 186, 0.05);
    margin: 1.5em 0;
    padding: 0.8em 1.2em;
    color: var(--content);
    border-radius: 0 4px 4px 0;
}
.dark .post-content blockquote p {
    margin-bottom: 0;
}

/* ---------- Tables ---------- */
.dark .post-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5em 0;
    font-size: 0.95rem;
}
.dark .post-content table th,
.dark .post-content table td {
    border-bottom: 1px solid var(--border);
    padding: 0.6em 1em;
    text-align: left;
}
.dark .post-content table th {
    font-weight: 600;
    color: var(--primary);
    background-color: rgba(255, 255, 255, 0.02);
}
.dark .post-content table tbody tr:hover {
    background-color: rgba(38, 152, 186, 0.05);
}

/* ---------- Figures / Images ---------- */
.dark .post-content figure {
    margin: 1.5em 0;
}
.dark .post-content figure figcaption {
    font-size: 0.875rem;
    color: var(--secondary);
    text-align: center;
    margin-top: 0.5em;
    font-style: italic;
}

/* ---------- HR ---------- */
.dark .post-content hr {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2em 0;
}

/* ---------- Header / Nav ---------- */
.dark .header {
    background-color: var(--theme);
    border-bottom: 1px solid var(--border);
}
.dark .logo a {
    color: var(--primary);
    font-family: 'Roboto Slab', Georgia, serif;
    font-weight: 500;
}
.dark .menu a {
    color: var(--content);
}
.dark .menu a:hover,
.dark .menu a.active {
    color: var(--accent);
    border-bottom: none;
}

/* ---------- Post list ---------- */
.dark .post-entry {
    background-color: var(--entry);
    border: 1px solid var(--border);
    border-radius: 6px;
    transition: border-color 0.15s ease;
}
.dark .post-entry:hover {
    border-color: var(--accent);
}
.dark .entry-header h2 {
    font-family: 'Roboto Slab', Georgia, serif;
    color: var(--primary);
}

/* ---------- Footer ---------- */
.dark .footer {
    color: var(--secondary);
    border-top: 1px solid var(--border);
}

/* ============================================================
   SIDEBAR STICKY ToC
   Works in both light and dark mode.
   PaperMod's default ToC renders inline at the top of the post.
   This override positions it as a right-side sticky panel on
   wide screens (>= 1400px), and falls back to inline on narrow
   screens.
   ============================================================ */

/* Wide screen: sticky sidebar on the right */
@media (min-width: 1400px) {
    .toc {
        position: fixed;
        top: 100px;
        right: calc((100vw - var(--main-width, 720px)) / 2 - 280px);
        width: 240px;
        max-height: calc(100vh - 150px);
        overflow-y: auto;
        padding: 0 1em;
        margin: 0;
        border: none;
        border-left: 1px solid var(--border);
        background: transparent;
        font-size: 0.875rem;
        z-index: 10;
    }

    .toc details {
        border: none;
        background: transparent;
        padding: 0;
    }

    .toc details summary {
        font-family: 'Roboto Slab', Georgia, serif;
        font-size: 1rem;
        font-weight: 500;
        color: var(--primary);
        margin-bottom: 0.8em;
        cursor: default;
        list-style: none;
    }
    .toc details summary::-webkit-details-marker,
    .toc details summary::marker {
        display: none;
    }

    .toc .inner {
        margin: 0;
        padding: 0;
    }

    .toc ul {
        list-style: none;
        padding-left: 0;
        margin: 0;
    }
    .toc ul ul {
        padding-left: 1em;
        margin-top: 0.3em;
    }
    .toc li {
        margin: 0.4em 0;
        line-height: 1.4;
    }
    .toc a {
        color: var(--secondary);
        text-decoration: none;
        border-bottom: none;
        transition: color 0.15s ease;
        display: block;
        padding: 2px 0;
    }
    .toc a:hover {
        color: var(--accent);
        border-bottom: none;
    }
    .toc a.active {
        color: var(--accent);
        font-weight: 500;
    }

    /* Custom scrollbar for ToC */
    .toc::-webkit-scrollbar {
        width: 3px;
    }
    .toc::-webkit-scrollbar-track {
        background: transparent;
    }
    .toc::-webkit-scrollbar-thumb {
        background: var(--border);
        border-radius: 3px;
    }
}

/* Narrow screen: keep PaperMod default inline ToC, but style it */
@media (max-width: 1399px) {
    .toc {
        background: var(--entry);
        border: 1px solid var(--border);
        border-radius: 6px;
        padding: 1em;
        margin: 1.5em 0;
    }
    .toc details summary {
        font-family: 'Roboto Slab', Georgia, serif;
        font-weight: 500;
        color: var(--primary);
    }
    .toc a {
        color: var(--accent);
        text-decoration: none;
    }
    .toc a:hover {
        color: var(--accent-hover);
    }
}

/* ============================================================
   READING EXPERIENCE TWEAKS
   ============================================================ */

/* Wider main content on desktop (closer to scaling-book's 930px) */
:root {
    --main-width: 760px;
}

.main {
    max-width: var(--main-width);
}

/* Smooth scroll for anchor links */
html {
    scroll-behavior: smooth;
}

/* Anchor offset so headings aren't hidden behind sticky header */
.post-content h1,
.post-content h2,
.post-content h3,
.post-content h4,
.post-content h5,
.post-content h6 {
    scroll-margin-top: 80px;
}

/* Selection color */
.dark ::selection {
    background-color: rgba(38, 152, 186, 0.3);
    color: var(--primary);
}
