/* ============================================================
   scaling-book dark style for Hugo PaperMod (FINAL)
   Based on actual DevTools computed values from
   https://jax-ml.github.io/scaling-book/

   - Dark mode only (light = PaperMod default)
   - Cyan accent #2698ba
   - Roboto (all weights, no Slab)
   - Left sidebar sticky ToC (scaling-book style)
   - Place at: assets/css/extended/custom.css
   ============================================================ */

/* ---------- Google Fonts: Roboto only ---------- */
@import url('https://fonts.googleapis.com/css2?family=Roboto:wght@100;300;400;500;600;700&family=Noto+Sans+KR:wght@300;400;500;700&display=swap');

/* ============================================================
   DARK MODE CSS VARS
   Values measured from scaling-book dark theme.
   ============================================================ */
.dark {
    --theme:      #1c1c1d;
    --entry:      #212529;
    --primary:    #e8e8e8;
    --secondary:  #828282;
    --tertiary:   #424246;
    --content:    #e8e8e8;
    --code-block-bg: #2c3237;
    --code-bg:    #2c3237;
    --border:     #424246;

    --accent:       #2698ba;
    --accent-hover: #3bb0d3;
}

/* ============================================================
   BASE TYPOGRAPHY (dark only)
   ============================================================ */
.dark body {
    font-family: 'Roboto', 'Noto Sans KR', -apple-system, BlinkMacSystemFont, sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 1.5;
    color: var(--content);
    background-color: var(--theme);
}

/* Post body slightly larger, more line-height (matches scaling-book d-article p) */
.dark .post-content,
.dark .post-content p,
.dark .post-content li {
    font-family: 'Roboto', 'Noto Sans KR', sans-serif;
    font-size: 16.96px;    /* = 1.06rem, scaling-book exact */
    line-height: 1.7;      /* 28.832px */
    color: var(--content);
}

/* ============================================================
   HEADINGS
   All Roboto, no Slab.
   ============================================================ */
.dark h1,
.dark h2,
.dark h3,
.dark h4,
.dark h5,
.dark h6,
.dark .post-title {
    font-family: 'Roboto', 'Noto Sans KR', sans-serif;
    color: var(--primary);
    letter-spacing: normal;
}

/* Post title (equivalent to scaling-book d-title h1) */
.dark .post-title {
    font-size: 50px;
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 12px;
}

/* h2: scaling-book exact — 36px / 600 / border-bottom */
.dark .post-content h2 {
    font-size: 36px;
    font-weight: 600;
    margin-top: 2em;
    margin-bottom: 24px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border);
}

.dark .post-content h3 {
    font-size: 24px;
    font-weight: 500;
    margin-top: 1.5em;
    margin-bottom: 16px;
}

.dark .post-content h4 {
    font-size: 20px;
    font-weight: 500;
}

/* ============================================================
   STRONG / EM
   scaling-book uses weight 500 for strong (not 700)
   ============================================================ */
.dark .post-content strong {
    font-weight: 500;
    color: var(--primary);
}

/* ============================================================
   LINKS
   Subtle underline on hover, like scaling-book's d-article a
   ============================================================ */
.dark a,
.dark .post-content a {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.15s ease;
}
.dark a:hover,
.dark .post-content a:hover {
    color: var(--accent);
    border-bottom: 1px solid var(--accent);
}

/* ============================================================
   INLINE CODE
   scaling-book: SFMono 14.84px, bg #2c3237, color #2698ba
   ============================================================ */
.dark .post-content code:not(pre code) {
    color: var(--accent);
    background-color: var(--code-bg);
    padding: 2px 6px;
    border-radius: 3px;
    font-family: 'SFMono-Regular', 'SF Mono', Menlo, Monaco, Consolas, monospace;
    font-size: 14.84px;
}

/* ============================================================
   CODE BLOCKS
   ============================================================ */
.dark .post-content pre {
    background-color: var(--code-block-bg);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 12px 16px;
    overflow-x: auto;
    font-family: 'SFMono-Regular', 'SF Mono', Menlo, Monaco, Consolas, monospace;
    font-size: 14.84px;
    line-height: 1.5;
}
.dark .post-content pre code {
    background: transparent;
    padding: 0;
    color: var(--content);
    font-size: inherit;
}

/* ============================================================
   BLOCKQUOTE
   scaling-book style: left border with accent, subtle bg
   ============================================================ */
.dark .post-content blockquote {
    border-left: 2px solid var(--accent);
    background: rgba(38, 152, 186, 0.05);
    margin: 1.5em 0;
    padding: 0.8em 1.2em;
    color: var(--content);
    border-radius: 0 4px 4px 0;
    font-size: 16.96px;
}
.dark .post-content blockquote p {
    margin-bottom: 0;
}

/* ============================================================
   TABLES
   ============================================================ */
.dark .post-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5em 0;
    font-size: 15px;
}
.dark .post-content table th,
.dark .post-content table td {
    border-bottom: 1px solid var(--border);
    padding: 8px 16px 8px 0;
    text-align: left;
}
.dark .post-content table th {
    font-weight: 600;
    color: var(--primary);
}
.dark .post-content table tbody tr:hover {
    background-color: rgba(38, 152, 186, 0.05);
}

/* ============================================================
   FIGURES
   ============================================================ */
.dark .post-content figure {
    margin: 1.5em 0;
}
.dark .post-content figure figcaption {
    font-size: 14px;
    color: var(--secondary);
    text-align: center;
    margin-top: 0.5em;
    font-style: italic;
}

/* ============================================================
   HR
   ============================================================ */
.dark .post-content hr {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2em 0;
}

/* ============================================================
   HEADER / NAVIGATION
   scaling-book: 57px height, opacity 0.95, thin border, Roboto 100 weight logo
   ============================================================ */
.dark .header {
    background-color: var(--theme);
    border-bottom: 1px solid var(--border);
    opacity: 0.95;
    height: 57px;
}
.dark .nav {
    height: 57px;
    padding: 8px 24px;
}
.dark .logo a {
    font-family: 'Roboto', sans-serif;
    font-weight: 300;   /* scaling-book uses 100, but 300 is more readable */
    font-size: 20px;
    color: var(--primary);
}
.dark .menu a {
    color: var(--content);
    font-weight: 400;
}
.dark .menu a:hover,
.dark .menu a.active {
    color: var(--accent);
    border-bottom: none;
}

/* ============================================================
   POST LIST (home page)
   Minimal entries, no card bg
   ============================================================ */
.dark .post-entry {
    background-color: transparent;
    border: none;
    border-bottom: 1px solid var(--border);
    border-radius: 0;
    padding: 24px 0;
    margin: 0;
    transition: none;
}
.dark .post-entry:hover {
    background: transparent;
    border-color: var(--border);
}
.dark .entry-header h2 {
    font-family: 'Roboto', sans-serif;
    font-weight: 500;
    font-size: 28px;
    color: var(--primary);
    border: none;
    padding: 0;
    margin: 0 0 8px 0;
}
.dark .entry-content {
    color: var(--secondary);
    font-size: 15px;
    line-height: 1.6;
    opacity: 1;
}
.dark .entry-footer {
    color: var(--secondary);
    font-size: 13px;
    margin-top: 8px;
}

/* ============================================================
   FOOTER
   ============================================================ */
.dark .footer {
    color: var(--secondary);
    border-top: 1px solid var(--border);
    padding: 40px 0;
    font-size: 14px;
    text-align: center;
}

/* ============================================================
   SIDEBAR STICKY ToC (LEFT side — scaling-book style)
   scaling-book uses grid-column 1/4 on left.
   PaperMod doesn't have that grid, so we use fixed positioning
   on wide screens.
   ============================================================ */
@media (min-width: 1400px) {
    .toc {
        position: fixed;
        top: 85px;
        left: max(20px, calc((100vw - 900px) / 2 - 280px));
        width: 240px;
        max-height: calc(100vh - 120px);
        overflow-y: auto;
        padding: 0 17px 0 17px;
        margin: 0;
        background: transparent;
        border: none;
        border-right: 1px solid var(--border);
        font-size: 13px;
        z-index: 10;
    }

    .toc details {
        border: none;
        background: transparent;
        padding: 0;
    }
    .toc details summary {
        font-family: 'Roboto', sans-serif;
        font-size: 20px;
        font-weight: 700;
        color: var(--primary);
        margin-bottom: 1em;
        list-style: none;
        cursor: default;
    }
    .toc details summary::-webkit-details-marker,
    .toc details summary::marker {
        display: none;
    }

    .toc .inner {
        margin: 0;
        padding: 0;
    }
    .toc ul {
        list-style: none;
        padding-left: 0;
        margin: 0;
    }
    .toc ul ul {
        padding-left: 16px;
        margin-top: 0.3em;
    }
    .toc li {
        margin: 0.4em 0;
        line-height: 1.4;
    }
    .toc a {
        color: var(--accent);
        text-decoration: none;
        border-bottom: none;
        display: block;
        padding: 2px 0;
        font-size: 13px;
        transition: color 0.15s ease;
    }
    .toc a:hover {
        color: var(--accent-hover);
        border-bottom: none;
    }
    .toc a.active {
        color: var(--accent);
        font-weight: 500;
    }

    .toc::-webkit-scrollbar {
        width: 3px;
    }
    .toc::-webkit-scrollbar-thumb {
        background: var(--border);
        border-radius: 3px;
    }
}

/* Narrow screen: inline ToC */
@media (max-width: 1399px) {
    .toc {
        background: var(--entry);
        border: 1px solid var(--border);
        border-radius: 6px;
        padding: 1em;
        margin: 1.5em 0;
    }
    .toc details summary {
        font-family: 'Roboto', sans-serif;
        font-weight: 500;
        color: var(--primary);
    }
    .toc a {
        color: var(--accent);
        text-decoration: none;
    }
}

/* ============================================================
   LAYOUT
   Wider main for reading
   ============================================================ */
:root {
    --main-width: 760px;
    --nav-width: 1024px;
}
.main {
    max-width: var(--main-width);
}

html {
    scroll-behavior: smooth;
}

.post-content h1,
.post-content h2,
.post-content h3,
.post-content h4,
.post-content h5,
.post-content h6 {
    scroll-margin-top: 80px;
}

.dark ::selection {
    background-color: rgba(38, 152, 186, 0.3);
    color: var(--primary);
}

/* ============================================================
   HOME PROFILE MODE OVERRIDE
   Remove rabbit image, scaling-book-style title
   ============================================================ */
.dark .profile {
    padding: 80px 20px 40px;
    min-height: auto;
    text-align: left;
    display: block;
}
.dark .profile img,
.dark .profile_img,
.dark .profile .profile_img {
    display: none !important;
}
.dark .profile .profile_inner h1 {
    font-size: 50px;
    font-weight: 700;
    color: var(--primary);
    margin-bottom: 12px;
    text-align: left;
    display: block;
}
.dark .profile .profile_inner #profile_description,
.dark .profile .profile_inner p {
    font-size: 22px;
    font-weight: 400;
    color: var(--primary);
    text-align: left;
    margin: 0 0 24px 0;
    opacity: 1;
}
.dark .profile .buttons,
.dark .profile .social-icons {
    justify-content: flex-start;
    margin-top: 24px;
}
.dark .profile .social-icons a {
    color: var(--content);
}
.dark .profile .social-icons a:hover {
    color: var(--accent);
    border-bottom: none;
}
