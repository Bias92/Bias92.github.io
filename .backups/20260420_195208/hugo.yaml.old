baseURL: "https://bias92.github.io/"  
languageCode: ko
defaultContentLanguage: ko
title: "굉장히 공격적이고 사나운 사람"
theme: "PaperMod"
pagination:
  pagerSize: 10

params:
  env: production
  description: "GPU Systems & Deep Learning Hardware"
  author: "노란토끼"
  defaultTheme: dark
  disableThemeToggle: false
  ShowReadingTime: true
  ShowShareButtons: false
  ShowPostNavLinks: true
  ShowBreadCrumbs: true
  ShowCodeCopyButtons: true
  ShowToc: true
  TocOpen: true
  comments: false

  homeInfoParams:
    Title: "굉장히 공격적이고 사나운 사람"
    Content: "GPU Systems & Deep Learning Hardware"

  socialIcons:
    - name: github
      url: "https://github.com/Bias92"

  assets:
    favicon: "/favicon.ico"
    disableFingerprinting: false

  cover:
    linkFullImages: true

menu:
  main:
    - identifier: home
      name: Home
      url: /
      weight: 1
    - identifier: posts
      name: Posts
      url: /posts/
      weight: 2
    - identifier: categories
      name: Categories
      url: /categories/
      weight: 3
    - identifier: tags
      name: Tags
      url: /tags/
      weight: 4
    - identifier: search
      name: Search
      url: /search/
      weight: 5

outputs:
  home:
    - HTML
    - RSS
    - JSON

markup:
  highlight:
    codeFences: true
    guessSyntax: true
    lineNos: false
    style: dracula
